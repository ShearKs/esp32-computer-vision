<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- Permitir tráfico cleartext (HTTP) a IPs de red local -->
    <base-config cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>

    <!-- Dominios específicos de red local -->
    <domain-config cleartextTrafficPermitted="true">
        <domain includeSubdomains="true">192.168.1.174</domain>
        <domain includeSubdomains="true">192.168.1.207</domain>
        <domain includeSubdomains="true">192.168.48.207</domain>
        <domain includeSubdomains="true">192.168.0.50</domain>
        <domain includeSubdomains="true">192.168.192.207</domain>
        <domain includeSubdomains="true">localhost</domain>
    </domain-config>
</network-security-config>
